<!-- HERO -->
<section class="hero d-flex align-items-center text-white">
    <div class="container text-center">

        <h1 class="hero-main-title  glow-text bounce-text">
            Welcome to LockForge!
        </h1>
        <h2 class="hero-title fw-bold">
            Manage Your Passwords <br> Securely & Effortlessly
        </h2>

        <p class="hero-subtitle mt-3">
            A secure vault for all your credentials with encryption and simplicity.
        </p>

        <div class="mt-4">
            <% if (!isLoggedIn) { %>
        <a href="/register" class="btn btn-primary btn-lg me-3">Get Started</a>
    <% } else { %>
        <a href="/dashboard" class="btn btn-success btn-lg me-3">Go to Dashboard</a>
    <% } %>
            <a href="#features" class="btn btn-outline-light btn-lg">Learn More</a>
        </div>

    </div>
</section>

<!-- FEATURES -->
