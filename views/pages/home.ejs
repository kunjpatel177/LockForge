                <p>Your data is encrypted and secure at all times.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card reveal p-4 text-center h-100">
                <div class="icon mb-3">⚡</div>
                <h5>Fast & Simple</h5>
                <p>Quick access to all your credentials anytime.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card reveal p-4 text-center h-100">
                <div class="icon mb-3">📱</div>
                <h5>Responsive Design</h5>
                <p>Works seamlessly across devices.</p>
            </div>
        </div>

    </div>
</section>

<!-- HOW IT WORKS -->
<section class="container py-5">
    <h2 class="text-center mb-5 fw-semibold">How It Works</h2>

    <div class="row text-center g-4">

        <div class="col-md-4">
            <div class="step-card reveal p-4">
                <div class="step-number">1</div>
                <h5>Create Account</h5>
                <p>Sign up securely with your master password.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="step-card reveal p-4">
                <div class="step-number">2</div>
                <h5>Add Credentials</h5>
                <p>Store your passwords and sensitive data safely.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="step-card reveal p-4">
                <div class="step-number">3</div>
                <h5>Access Anytime</h5>
                <p>Retrieve your data securely from anywhere.</p>
            </div>
        </div>

    </div>
</section>

<!-- SECURITY SECTION -->
<section class="security-section text-white text-center py-5">
    <div class="container">
        <h2 class="fw-bold">🔒 Security You Can Trust</h2>
        <p class="mt-3">
            We use AES-256 encryption and secure authentication mechanisms
            to ensure your data is always protected.
        </p>
    </div>
</section>

