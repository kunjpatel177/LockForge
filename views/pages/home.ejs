<!-- HERO -->
<section class="hero d-flex align-items-center text-white">
    <div class="container text-center">

        <h1 class="hero-main-title glow-text bounce-text">
            Welcome to LockForge
        </h1>

        <h2 class="hero-title fw-bold">
            Manage Your Passwords <br> Securely & Effortlessly
        </h2>

        <p class="hero-subtitle mt-3">
            A secure vault designed to protect your digital identity with advanced encryption.
        </p>

        <div class="mt-4">
            <% if (!isLoggedIn) { %>
                <a href="/register" class="btn btn-primary btn-lg me-3">
                    Get Started
                </a>
            <% } else { %>
                <a href="/dashboard" class="btn btn-success btn-lg me-3">
                    Go to Dashboard
                </a>
            <% } %>

            <a href="#features" class="btn btn-outline-light btn-lg">
                Learn More
            </a>
        </div>

    </div>
</section>


<!-- FEATURES -->
<section id="features" class="container py-5">
    <h2 class="text-center mb-5 fw-semibold">Why Choose Us?</h2>

    <div class="row g-4">

        <div class="col-12 col-md-4">
            <div class="feature-card reveal p-4 text-center h-100">
                <i class="fa-solid fa-lock fa-2x mb-3"></i>
                <h5>End-to-End Encryption</h5>
                <p>Your data is encrypted using industry-standard AES-256 encryption.</p>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="feature-card reveal p-4 text-center h-100">
                <i class="fa-solid fa-bolt fa-2x mb-3"></i>
                <h5>Fast & Simple</h5>
                <p>Access and manage your credentials quickly with a clean interface.</p>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="feature-card reveal p-4 text-center h-100">
                <i class="fa-solid fa-mobile-screen-button fa-2x mb-3"></i>
                <h5>Responsive Design</h5>
                <p>Works seamlessly across desktop, tablet, and mobile devices.</p>
            </div>
        </div>

    </div>
</section>


<!-- HOW IT WORKS -->
<section class="container py-5">
    <h2 class="text-center mb-5 fw-semibold">How It Works</h2>

    <div class="row text-center g-4">

        <div class="col-12 col-md-4">
            <div class="step-card reveal p-4">
                <i class="fa-solid fa-user-plus fa-2x mb-3"></i>
                <h5>Create Account</h5>
                <p>Register securely using a strong master password.</p>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="step-card reveal p-4">
                <i class="fa-solid fa-database fa-2x mb-3"></i>
                <h5>Add Credentials</h5>
                <p>Store passwords and sensitive data in encrypted format.</p>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="step-card reveal p-4">
                <i class="fa-solid fa-unlock-keyhole fa-2x mb-3"></i>
                <h5>Access Anytime</h5>
                <p>Retrieve your data securely whenever you need it.</p>
            </div>
        </div>

    </div>
</section>


<!-- SECURITY -->
<section class="security-section text-white text-center py-5">
    <div class="container">
        <h2 class="fw-bold">
            <i class="fa-solid fa-shield-halved me-2"></i>
            Security You Can Trust
        </h2>
        <p class="mt-3">
            Built with AES-256 encryption, PBKDF2 key derivation, and secure session handling.
        </p>
    </div>
</section>


<!-- TESTIMONIALS -->
<section class="container py-5">
    <h2 class="text-center mb-5 fw-semibold">What Users Say</h2>

    <div class="row g-4">

        <div class="col-12 col-md-4">
            <div class="testimonial-card p-4 reveal">
                <p>"A secure and intuitive solution for managing credentials."</p>
                <h6 class="mt-3">— Kunj Patel</h6>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="testimonial-card p-4 reveal">
                <p>"Clean UI with strong encryption features. Highly recommended."</p>
                <h6 class="mt-3">— Developer</h6>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="testimonial-card p-4 reveal">
                <p>"Simple, fast, and secure password management experience."</p>
                <h6 class="mt-3">— User</h6>
            </div>
        </div>

    </div>
</section>


<!-- FINAL CTA -->
<section class="cta text-center text-white py-5">
    
    <% if (!isLoggedIn) { %>
        <h2>Start Securing Your Data Today</h2>
        <p class="mt-2">Protect your credentials with advanced security and ease of use.</p>
        <a href="/register" class="btn btn-light btn-lg mt-3">Create Account</a>
        <% } else { %>
            <h2>Continue Securing Your Data Today</h2>
            <p class="mt-2">Protect your credentials with advanced security and ease of use.</p>
        <a href="/dashboard" class="btn btn-light btn-lg mt-3">Go to Dashboard</a>
    <% } %>
</section>


<!-- NEW PROFESSIONAL SECTION -->
<section class="container py-5 text-center">

    <h3 class="fw-semibold mb-4">Why LockForge?</h3>

    <div class="row g-4">

        <div class="col-12 col-md-4">
            <div class="stat-card p-4">
                <i class="fa-solid fa-user-shield fa-2x mb-2"></i>
                <h4>Secure</h4>
                <p class="text-muted">Designed with modern security practices.</p>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="stat-card p-4">
                <i class="fa-solid fa-cloud-arrow-up fa-2x mb-2"></i>
                <h4>Reliable</h4>
                <p class="text-muted">Your data is always available and protected.</p>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="stat-card p-4">
                <i class="fa-solid fa-layer-group fa-2x mb-2"></i>
                <h4>Scalable</h4>
                <p class="text-muted">Built to handle growing data securely.</p>
            </div>
        </div>

    </div>

</section>