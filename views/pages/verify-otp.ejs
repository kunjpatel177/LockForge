<div class="otp-page">
    <div class="otp-container">
        <div class="otp-header">
            <div class="otp-icon">
                <i class="fa-solid fa-shield-halved"></i>
            </div>
            <h2>Identity Verification</h2>
            <p>For security reasons, we need to verify your login attempt.</p>
            <div class="email-box">
                <i class="fa-solid fa-envelope"></i>
                <span>Code sent to <strong>
                        <%= maskedEmail || "your email" %>
                    </strong></span>
            </div>
        </div>

        <form id="otpForm" onsubmit="return false;">
            <input type="hidden" id="csrfToken" value="<%= csrfToken %>">
            <div class="otp-input-wrapper">
                <input type="text" name="otp" maxlength="6" class="otp-input" placeholder="Enter 6-digit code"
                    autocomplete="off" required>
            </div>
            <button type="submit" class="verify-btn">
                <i class="fa-solid fa-arrow-right-to-bracket me-1"></i>
                Verify & Continue
            </button>
        </form>

        <div id="error" class="otp-error"></div>

        <div class="otp-footer">
            <p>Didn’t receive the code?</p>
            <a href="#" id="resendLink" class="resend-link disabled-link">Resend OTP</a>
            <div id="countdown" class="countdown"></div>
        </div>

        <div class="security-note">
            <i class="fa-solid fa-lock"></i>
            <span>Your account is protected by adaptive authentication.</span>
        </div>

        <a href="/cancel-otp" class="back-btn btn btn-dark">
            <i class="fa-solid fa-arrow-left me-1"></i>Go Back to Homepage
        </a>
    </div>
</div>