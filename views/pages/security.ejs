<section class="security-hero">

    <div class="container">

        <div class="d-flex justify-content-end mb-4">
            <% if (isLoggedIn) { %>
                <a href="/" class="btn btn-outline-light me-3">
                    <i class="fa-solid fa-house"></i> Home
                </a>

                <a href="/dashboard" class="btn btn-light">
                    <i class="fa-solid fa-chart-line"></i> Dashboard
                </a>
                <% } else { %>
                    <a href="/" class="btn btn-light btn-lg">
                        <i class="fa-solid fa-house"></i> Home
                    </a>
                    <% } %>
        </div>

        <div class="text-center">

            <div class="security-badge">
                <i class="fa-solid fa-shield-halved"></i>
                Enterprise-Inspired Security
            </div>

            <h1 class="display-5 fw-bold mt-4">
                Security Architecture
            </h1>

            <p class="lead mt-3">
                LockForge is designed around modern security principles including
                encryption, session monitoring, adaptive authentication and secure credential storage.
            </p>

        </div>

    </div>

</section>

<section class="container py-5">

    <!-- SECURITY OVERVIEW -->

    <div class="row g-4 mb-5">

        <div class="col-md-3">
            <div class="security-stat-card">
                <i class="fa-solid fa-lock"></i>
                <h3>AES-256</h3>
                <p>Credential Encryption</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="security-stat-card">
                <i class="fa-solid fa-key"></i>
                <h3>PBKDF2</h3>
                <p>Key Derivation</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="security-stat-card">
                <i class="fa-solid fa-mobile-screen"></i>
                <h3>OTP</h3>
                <p>Adaptive Authentication</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="security-stat-card">
                <i class="fa-solid fa-desktop"></i>
                <h3>Sessions</h3>
                <p>Device Tracking</p>
            </div>
        </div>

    </div>

    <!-- FLOW -->

    <div class="section-card mb-5">

        <h3 class="section-title">
            <i class="fa-solid fa-diagram-project"></i>
            Credential Protection Flow
        </h3>

        <div class="flow-box">

            <div class="flow-step">
                <i class="fa-solid fa-user-lock"></i>
                <span>User Authentication</span>
            </div>

            <div class="flow-arrow">
                <i class="fa-solid fa-arrow-right"></i>
            </div>

            <div class="flow-step">
                <i class="fa-solid fa-key"></i>
                <span>PBKDF2 Key Derivation</span>
            </div>

            <div class="flow-arrow">
                <i class="fa-solid fa-arrow-right"></i>
            </div>

            <div class="flow-step">
                <i class="fa-solid fa-lock"></i>
                <span>AES Encryption</span>
            </div>

            <div class="flow-arrow">
                <i class="fa-solid fa-arrow-right"></i>
            </div>

            <div class="flow-step">
                <i class="fa-solid fa-database"></i>
                <span>Encrypted Storage</span>
            </div>

        </div>

    </div>

    <!-- SECURITY LAYERS -->

    <div class="section-card mb-5">

        <h3 class="section-title">
            <i class="fa-solid fa-layer-group"></i>
            Security Layers
        </h3>

        <div class="row g-4">

            <div class="col-md-6">
                <div class="security-layer">
                    <h5>Authentication Layer</h5>
                    <p>
                        Secure login with bcrypt password verification and OTP-based adaptive authentication.
                    </p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="security-layer">
                    <h5>Encryption Layer</h5>
                    <p>
                        Sensitive credentials are encrypted using AES before database storage.
                    </p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="security-layer">
                    <h5>Session Security</h5>
                    <p>
                        Device-aware sessions with activity tracking and remote session revocation.
                    </p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="security-layer">
                    <h5>Application Security</h5>
                    <p>
                        CSRF protection, rate limiting, secure cookies and input validation.
                    </p>
                </div>
            </div>

        </div>

    </div>

    <!-- THREAT MODEL -->

    <div class="section-card mb-5">

        <h3 class="section-title">
            <i class="fa-solid fa-triangle-exclamation"></i>
            Threat Mitigation
        </h3>

        <div class="row g-4">

            <div class="col-md-6">
                <div class="threat-card">
                    <h5>Database Breach</h5>
                    <p>Stored credentials remain unreadable because they are encrypted before storage.</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="threat-card">
                    <h5>Brute Force Attack</h5>
                    <p>Rate limiting and PBKDF2 key stretching significantly increase attack cost.</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="threat-card">
                    <h5>Session Hijacking</h5>
                    <p>Secure cookies, session monitoring and remote logout reduce exposure.</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="threat-card">
                    <h5>Suspicious Login</h5>
                    <p>OTP verification activates when login patterns differ from historical activity.</p>
                </div>
            </div>

        </div>

    </div>

    <!-- TECHNOLOGIES -->

    <div class="section-card">

        <h3 class="section-title">
            <i class="fa-solid fa-microchip"></i>
            Technologies Used
        </h3>

        <div class="tech-grid">

            <span class="tech-pill">Node.js</span>
            <span class="tech-pill">Express.js</span>
            <span class="tech-pill">MongoDB</span>
            <span class="tech-pill">AES-256-CBC</span>
            <span class="tech-pill">PBKDF2</span>
            <span class="tech-pill">bcrypt</span>
            <span class="tech-pill">CSRF</span>
            <span class="tech-pill">Rate Limiting</span>
            <span class="tech-pill">Session Tracking</span>

        </div>

    </div>

</section>