    <div class="container">

        <h2 class="fw-bold mb-3">
            Secure Your Credentials Today
        </h2>

        <p class="text-muted mb-4">
            Take control of your passwords with a platform designed around security.
        </p>

        <% if (isLoggedIn) { %>

            <a href="/dashboard" class="btn btn-dark btn-lg">
