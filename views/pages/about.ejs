        <h3 class="mb-3 fw-semibold">Continue Securing Your Credentials Today</h3>
        <a href="/dashboard" class="btn btn-dark btn-lg px-4">
            Dashboard
        </a>
        <% } else { %>
            <h3 class="mb-3 fw-semibold">Start Securing Your Credentials Today</h3>
            <a href="/register" class="btn btn-dark btn-lg px-4">
        Create Account
    </a>
        <% } %>

</section>
