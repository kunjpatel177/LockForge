<section class="about-hero d-flex align-items-center">
    <div class="container text-center">

        <h1 class="fw-bold display-5 mb-3">
            Secure Password Management for Modern Users
        </h1>

        <p class=" mb-4">
            LockForge helps you store, manage, and protect your credentials with strong encryption and advanced security features.
        </p>

        <% if (isLoggedIn) { %>
            <a href="/dashboard" class="btn btn-danger btn-lg px-4">
                Dashboard
            </a>
        <% } else { %>
            <a href="/register" class="btn btn-primary btn-lg px-4">
                Get Started
            </a>
        <% } %>
        <a href="/" class="btn btn-outline-light btn-lg px-4 mx-3">
            Home Page
        </a>

    </div>
</section>


<!-- ================= FEATURES ================= -->
<section class="container py-5">

    <div class="row g-4">

        <div class="col-12 col-md-4">
            <div class="about-card text-center p-4">
                <i class="fa-solid fa-lock fa-2x mb-3"></i>
                <h5>End-to-End Encryption</h5>
                <p class="text-muted">
                    Your data is encrypted using AES-256 and can only be accessed using your master password.
                </p>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="about-card text-center p-4">
                <i class="fa-solid fa-shield-halved fa-2x mb-3"></i>
                <h5>Secure Authentication</h5>
                <p class="text-muted">
                    Password hashing with bcrypt and secure session management ensure strong protection.
                </p>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="about-card text-center p-4">
                <i class="fa-solid fa-mobile-screen-button fa-2x mb-3"></i>
                <h5>Device Tracking</h5>
                <p class="text-muted">
                    Monitor active sessions and detect suspicious logins across devices.
                </p>
            </div>
        </div>

    </div>

</section>


<!-- ================= SECURITY ================= -->
<section class="about-section bg-light py-5">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-md-6">
                <h3 class="fw-semibold mb-3">Security Architecture</h3>

                <ul class="list-unstyled">

                    <li class="mb-2">
                        <i class="fa-solid fa-check me-2 text-primary"></i>
                        AES-256 Encryption for sensitive fields
                    </li>

                    <li class="mb-2">
                        <i class="fa-solid fa-check me-2 text-primary"></i>
                        PBKDF2-based key derivation
                    </li>

                    <li class="mb-2">
                        <i class="fa-solid fa-check me-2 text-primary"></i>
                        Password hashing using bcrypt
                    </li>

                    <li class="mb-2">
                        <i class="fa-solid fa-check me-2 text-primary"></i>
                        CSRF protection & rate limiting
                    </li>

                    <li class="mb-2">
                        <i class="fa-solid fa-check me-2 text-primary"></i>
                        OTP verification for new devices
                    </li>

                </ul>
            </div>

            <div class="col-md-6 text-center">
                <i class="fa-solid fa-user-shield fa-6x text-primary opacity-75"></i>
            </div>

        </div>

    </div>

</section>


<!-- ================= HOW IT WORKS ================= -->
<section class="container py-5">

    <h3 class="text-center mb-5 fw-semibold">How It Works</h3>

    <div class="row text-center g-4">

        <div class="col-12 col-md-4">
            <i class="fa-solid fa-key fa-2x mb-3"></i>
            <h6>Create Master Password</h6>
            <p class="text-muted small">
                Your master password generates a secure encryption key.
            </p>
        </div>

        <div class="col-12 col-md-4">
            <i class="fa-solid fa-database fa-2x mb-3"></i>
            <h6>Store Encrypted Data</h6>
            <p class="text-muted small">
                All credentials are encrypted before being saved.
            </p>
        </div>

        <div class="col-12 col-md-4">
            <i class="fa-solid fa-unlock-keyhole fa-2x mb-3"></i>
            <h6>Access Securely</h6>
            <p class="text-muted small">
                Only you can decrypt your data using your password.
            </p>
        </div>

    </div>

</section>


<!-- ================= DEVELOPER ================= -->
<section class="about-developer-section bg-light py-5">

    <div class="container text-center">

        <h3 class="mb-3 fw-semibold text-light">Developer</h3>

        <p class="text-light">
            Built by <strong>Kunj Patel</strong> as a secure password manager project
            demonstrating modern security practices and scalable backend architecture.
        </p>

    </div>

</section>


