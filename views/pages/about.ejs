            <div class="tech-card">EJS</div>
        </div>

        <div class="col-md-2 col-6">
            <div class="tech-card">Bootstrap</div>
        </div>

        <div class="col-md-2 col-6">
            <div class="tech-card">AES + PBKDF2</div>
        </div>

    </div>


</section>

<!-- DEVELOPER -->

