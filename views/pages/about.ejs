<section class="about-hero d-flex align-items-center">


    <div class="container text-center">

        <span class="about-badge">
            <i class="fa-solid fa-shield-halved"></i>
            Secure Password Management Platform
        </span>

        <h1 class="display-4 fw-bold mt-4 mb-3">
            Protect Your Digital Identity with LockForge
        </h1>

        <p class="about-subtitle mx-auto">
            LockForge is a modern password management solution designed to securely
            store credentials using strong encryption, adaptive authentication,
            session monitoring, and security-focused architecture.
        </p>

        <div class="mt-4">

            <% if (isLoggedIn) { %>
                <a href="/dashboard" class="btn btn-primary btn-lg px-4">
                    <i class="fa-solid fa-chart-line me-2"></i>
                    Dashboard
                </a>
                <% } else { %>
                    <a href="/register" class="btn btn-primary btn-lg px-4">
                        <i class="fa-solid fa-user-plus"></i>
                        Get Started
                    </a>
                    <% } %>

                        <a href="/" class="btn btn-outline-light btn-lg px-4 ms-2">
                            <i class="fa-solid fa-house me-2"></i>
                            Home
                        </a>

        </div>

    </div>


</section>

<!-- STATS -->

<section class="container py-5">


    <div class="row g-4 text-center">

        <div class="col-md-3">
            <div class="stats-card">
                <h2>256-bit</h2>
                <p>AES Encryption</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stats-card">
                <h2>PBKDF2</h2>
                <p>Key Derivation</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stats-card">
                <h2>OTP</h2>
                <p>Adaptive Authentication</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stats-card">
                <h2>24/7</h2>
                <p>Credential Access</p>
            </div>
        </div>

    </div>


</section>

<!-- MISSION -->

<section class="container py-5">


    <div class="row align-items-center">

        <div class="col-lg-6">

            <h2 class="fw-bold mb-4">
                Why LockForge?
            </h2>

            <p class="text-muted">
                Password reuse, weak passwords, and credential theft remain among
                the most common security risks. LockForge was created to help users
                securely manage sensitive credentials while maintaining a simple
                and intuitive experience.
            </p>

            <p class="text-muted">
                The platform combines encryption, authentication, device tracking,
                audit logging, and session management into a single security-focused
                application.
            </p>

        </div>

        <div class="col-lg-6 text-center">

            <div class="mission-icon">
                <i class="fa-solid fa-user-shield"></i>
            </div>

        </div>

    </div>


</section>

<!-- FEATURES -->

<section class="bg-light py-5">


    <div class="container">

        <div class="text-center mb-5">
            <h2 class="fw-bold">Core Security Features</h2>
            <p class="text-muted">
                Designed with multiple layers of protection.
            </p>
        </div>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="about-card">
                    <i class="fa-solid fa-lock"></i>
                    <h5>Encrypted Storage</h5>
                    <p>
                        Sensitive fields are encrypted using AES-256 before
                        being stored in the database.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="about-card">
                    <i class="fa-solid fa-key"></i>
                    <h5>Secure Key Generation</h5>
                    <p>
                        PBKDF2 derives strong encryption keys from the
                        master password.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="about-card">
                    <i class="fa-solid fa-mobile-screen-button"></i>
                    <h5>Session Monitoring</h5>
                    <p>
                        View active sessions and remotely logout
                        suspicious devices.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="about-card">
                    <i class="fa-solid fa-envelope-circle-check"></i>
                    <h5>OTP Verification</h5>
                    <p>
                        New devices and unusual logins trigger
                        additional authentication.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="about-card">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    <h5>Audit History</h5>
                    <p>
                        Every important account activity is logged
                        for transparency and monitoring.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="about-card">
                    <i class="fa-solid fa-file-pdf"></i>
                    <h5>Secure Export</h5>
                    <p>
                        Export credentials securely after password
                        verification.
                    </p>
                </div>
            </div>

        </div>

    </div>


</section>

