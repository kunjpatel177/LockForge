<div class="container-fluid auth-container">
    <div class="row auth-row">

        <!-- LEFT SIDE -->
        <div class="col-md-6 auth-left">
            <h1>Create Account</h1>
            <p class="mt-3">
                Start managing your passwords securely and efficiently.
            </p>
            <div class="instructions">
                <h4 class="fw-bold">Instructions to create Password</h4>
                <hr>
                <h5>Password must contains at least: </h5>
                <ul>
                    <li>1 uppercase</li>
                    <li>1 lowercase</li>
                    <li>1 number</li>
                    <li>1 special character</li>
                    <li>8 characters</li>
                </ul> <hr>
                <h5 class="text-warning text-center"><i class="fa-solid fa-triangle-exclamation"></i> Please remember your password carefully. If you forget it, you will permanently lose access to your credentials.</h5>
            </div>
        </div>

        <!-- RIGHT SIDE -->
        <div class="col-md-6 auth-right">

            <div class="auth-card">

                <h3 class="text-center mb-3">Register</h3>
                <hr>

                <!-- IMPORTANT: AJAX FORM -->
                <form id="registerForm">

                    <!-- CSRF -->
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <!-- FULL NAME -->
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input type="text" name="fullName" class="form-control" placeholder="Enter your full name">
                    </div>

                    <!-- EMAIL -->
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="text" name="email" class="form-control" placeholder="Enter your email">
                    </div>

                    <!-- USERNAME -->
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" name="username" class="form-control" placeholder="Choose a username">
                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-3 position-relative">
                        <label class="form-label">Password</label>

                        <div class="d-flex align-items-center">
                            <input type="password" name="password" id="password" class="form-control"
                                placeholder="Create a strong password" >

                            <!-- 👁️ TOGGLE BUTTON OUTSIDE INPUT -->
                            <button type="button" class="btn btn-outline-secondary ms-2 toggle-password"
                                data-target="password">
                                <i class="fa fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <!-- SUBMIT -->
                    <button class="btn btn-primary w-100">
                        Register
                    </button>

                </form>

                <!-- LINK -->
                <p class="text-center mt-3">
                    Already have an account?
                    <a href="/login">Login</a>
                </p>

                <a class="btn btn-outline-dark d-flex justify-content-center" href="/">Go back to Home page</a>

            </div>

        </div>

    </div>
</div>