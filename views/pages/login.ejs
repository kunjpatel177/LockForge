<div class="container-fluid auth-container">
    <div class="row auth-row">

        <!-- LEFT SIDE -->
        <div class="col-md-6 auth-left">
            <h1>Welcome Back <i class="fa-solid fa-door-open"></i></h1>
            <p class="mt-3">
                Securely access your passwords anytime, anywhere.
            </p>
        </div>

        <!-- RIGHT SIDE -->
        <div class="col-md-6 auth-right">

            <div class="auth-card">

                <h3 class="text-center mb-3">Login</h3>
                <hr>

                <!-- IMPORTANT: NO action, NO method (AJAX handles it) -->
                <form id="loginForm">

                    <!-- CSRF -->
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <!-- EMAIL -->
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input 
                            type="email" 
                            name="email"
                            class="form-control"
                            placeholder="Enter your email"
                            required
                        >
                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input 
                            type="password" 
                            name="password"
                            class="form-control"
                            placeholder="Enter your password"
                            required
                        >
                    </div>

                    <!-- SUBMIT -->
                    <button class="btn btn-success w-100">
                        Login
                    </button>

                </form>

                <!-- LINK -->
                <p class="text-center mt-3">
                    Don’t have an account? 
                    <a href="/register">Register</a>
                </p>

                
                <a class="btn btn-outline-dark d-flex justify-content-center" href="/">Go back to Home page</a>
            </div>
            
        </div>

    </div>
</div>