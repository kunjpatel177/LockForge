<% if (suspiciousLogin) { %>
    <div class="alert alert-danger d-flex justify-content-between align-items-center shadow-sm">
        <div>
            <i class="fa-solid fa-triangle-exclamation"></i> <strong>Suspicious Login Detected!</strong><br>
            We noticed a login from a new device or location.
        </div>
        <a href="/history" class="btn btn-outline-danger btn-sm">
            Review Activity
        </a>
    </div>
    <% } %>

        <!-- HEADER -->
        <div class="dashboard-header">
            <h2 class="fw-semibold">My Credentials</h2>

            <div class="header-actions">
                <button class="btn btn-success btn-sm" onclick="openExportModal()">
                    <i class="fa-solid fa-file"></i> Export PDF
                </button>
                <button class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal">
                    Delete Account
                </button>
            </div>

        </div>

        <!-- 🔍 SEARCH BAR -->
        <div class="search-bar mb-3">
            <label for="searchInput" class="form-lable">Search your existing service:&nbsp;</label>
            <input type="text" id="searchInput" class="form-control"
                placeholder="Search service (e.g. Gmail, Instagram...)">
        </div>

        <!-- NO RESULT MESSAGE -->
        <p id="noResults" class=" mt-2" style="display:none;">
            No matching services found.
        </p>

        <!-- ================= ADD CREDENTIAL ================= -->

        <div class="credential-card add-card">
            <h4 class="mb-3 text-center ">Add Your Service Here</h4>
            <!-- <hr> -->

            <form id="addForm">

                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <div class="mb-3">
                    <input type="text" name="service" class="form-control" placeholder="Service (e.g. Gmail)" required>
                </div>

                <div id="fieldsContainer"></div>
                <p id="error" class="text-center"></p>

                <button type="button" id="addFieldBtn" class="btn btn-outline-primary btn-sm px-4 py-2 mt-2">
                    <i class="fa fa-plus"></i> Add Field
                </button>

                <br><br>

                <button class="btn btn-primary px-4 py-2">
                    Save Credential
                </button>

            </form>

        </div>

        <!-- ================= DISPLAY ================= -->

        <% if (!credentials || credentials.length===0) { %>
            <p class="text-muted mt-3">No credentials found.</p>
            <% } %>

                <div class="row mt-4">

                    <% credentials.forEach(cred=> { %>

                        <div class="col-md-6 mb-4 d-flex">

                            <!-- <div class="credential-card w-100"> -->
                            <div class="credential-card w-100 credential-item"
                                data-search="<%= cred.service.toLowerCase() %>">

                                <!-- HEADER -->
                                <div class="card-header">
                                    <h5>
                                        <%= cred.service %>
                                    </h5>

                                    <div class="card-actions">
                                        <a href="/edit/<%= cred._id %>" class="btn btn-sm btn-primary">Edit</a>

                                        <form method="POST" action="/delete/<%= cred._id %>">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button class="btn btn-sm btn-danger">Delete</button>
                                        </form>
                                    </div>
                                </div>

                                <hr>

                                <!-- FIELDS -->
                                <div class="card-body">

                                    <% cred.fields.forEach(field=> { %>

                                        <div class="field-row">

                                            <span class="field-label">
                                                <%= field.label %>:
                                            </span>

                                            <span class="field-value">

                                                <% if (["password","otp","code"].includes(field.type)) { %>

                                                    <span id="hidden-<%= field._id %>">••••••••</span>

                                                    <span id="real-<%= field._id %>" style="display:none;">
                                                        <%= field.value %>
                                                    </span>

                                                    <% } else { %>
                                                        <%= field.value %>
                                                            <% } %>

                                            </span>

                                            <div class="field-actions">

                                                <% if (["password","otp","code"].includes(field.type)) { %>
                                                    <button type="button" class="icon-btn toggle-btn"
                                                        data-id="<%= field._id %>">
                                                        <i class="fa fa-eye"></i>
                                                    </button>
                                                    <% } %>

                                                        <button type="button" class="icon-btn copy-btn"
                                                            data-value="<%= field.value %>">
                                                            <i class="fa fa-copy"></i>
                                                        </button>

                                            </div>

                                        </div>

                                        <% }) %>

                                </div>

                            </div>

                        </div>

                        <% }) %>

                </div>

                <!-- <script src="/js/script.js"></script> -->

                <!-- ================= DELETE ACCOUNT MODAL ================= -->

                <!-- DELETE ACCOUNT MODAL -->
                <div class="modal fade" id="deleteModal" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">

                            <div class="modal-header">
                                <h5 class="modal-title text-danger">⚠️ Delete Account</h5>
                                <button class="btn-close" data-bs-dismiss="modal"></button>
                            </div>

                            <div class="modal-body">
                                <p>This action is permanent. Enter your password to confirm.</p>

                                <div class="d-flex align-items-center">
                                    <input type="password" id="deletePassword" class="form-control"
                                        placeholder="Enter your password">

                                    <!-- 👁️ TOGGLE BUTTON -->
                                    <button type="button" class="btn btn-outline-secondary ms-2 toggle-password"
                                        data-target="deletePassword">
                                        <i class="fa fa-eye"></i>
                                    </button>
                                </div>

                                <div id="deleteError" class="text-danger mt-2"></div>
                            </div>

                            <div class="modal-footer">
                                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button id="confirmDelete" class="btn btn-danger">
                                    Delete
                                </button>
                            </div>

                        </div>
                    </div>
                </div>


                <div class="modal fade" id="exportModal" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content p-4 rounded-4 shadow">

                            <!-- HEADER -->
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="fw-semibold m-0 text-center"><i class="fa-solid fa-file-shield me-1"></i>Export Credentials</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>

                            <p class="text-muted small mb-3">
                                Enter your master password to securely export your credentials.
                            </p>

                            <!-- PASSWORD FIELD -->
                            <div class="mb-3">

                                <!-- INPUT GROUP -->
                                <div class="position-relative d-flex">

                                    <input type="password" id="exportPassword" name="password" class="form-control pe-5"
                                        placeholder="Enter your password">

                                    <!-- TOGGLE BUTTON -->
                                    <button type="button" class="btn btn-outline-secondary ms-2 toggle-password"
                                        data-target="exportPassword">
                                        <i class="fa fa-eye"></i>
                                    </button>

                                </div>

                                <!-- ERROR WILL COME HERE -->

                            </div>

                            <!-- ACTION BUTTON -->
                            <button class="btn btn-primary w-100 fw-medium" onclick="exportPDF()">
                                📄 Export PDF
                            </button>

                        </div>
                    </div>
                </div>