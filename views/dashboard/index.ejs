<% if (suspiciousLogin) { %>
    <div class="alert alert-danger d-flex justify-content-between align-items-center shadow-sm">
        <div>
            ⚠️ <strong>Suspicious Login Detected!</strong><br>
            We noticed a login from a new device or location.
        </div>
        <a href="/history" class="btn btn-outline-danger btn-sm">
            Review Activity
        </a>
    </div>
<% } %>

<!-- HEADER -->
<div class="dashboard-header">
    <h2>My Credentials</h2>

    <div class="header-actions">
        <a href="/sessions" class="btn btn-outline-primary btn-sm">
            🟢 Active Sessions
        </a>

        <a href="/history" class="btn btn-outline-secondary btn-sm">
            📜 Activity History
        </a>
    </div>
</div>

