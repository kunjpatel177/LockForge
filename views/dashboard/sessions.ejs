<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Active Sessions</h2>
            <p class="text-muted mb-0">Manage devices currently logged into your account</p>
        </div>
        <div class="d-flex">
            <% if ( sessions.length> 1) { %>
                <span>
                    <form method="POST" action="/sessions/logout-all" class="mb-3">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                        <button class="btn btn-danger py-2 me-3"
                            onclick="return confirm('Logout from all other devices?')">
                            <i class="fa-solid fa-power-off"></i> Logout All Other Devices
                        </button>
                    </form>
                </span>
                <% } %>
                    <span>
                        <a href="/dashboard" class="btn btn-dark px-3 py-2 ">
                            <span> <i class="fa-solid fa-arrow-left-long"></i> Back to Dashboard</span>
                        </a>
                    </span>

        </div>
    </div>


    <!-- WRAPPER CARD -->
    <div class="card border-0 shadow-sm rounded-4 p-3 sessions-info">
        <% if (sessions && sessions.length> 0) { %>

            <% sessions.forEach(session=> { %>

                <div class="session-card d-flex justify-content-between align-items-center p-3 mb-3 rounded-3">

                    <!-- LEFT INFO -->
                    <div class="d-flex flex-column">

                        <!-- TOP ROW -->
                        <div class="d-flex align-items-center gap-2 mb-1">

                            <% if (session.sessionId===currentSessionId) { %>
                                <span class="badge bg-success">Current</span>
                                <% } else { %>
                                    <span class="badge bg-secondary">Active</span>
                                    <% } %>

                                        <strong>
                                            <%= session.device %>
                                        </strong>
                        </div>

                        <!-- META INFO -->
                        <div class="text-muted small">
                            IP: <code><%= session.ip %></code> •
                            <%= session.location %>
                        </div>

                        <div class="text-muted small">
                            Last active: <%= session.lastActive.toLocaleString("en-IN", { timeZone: "Asia/Kolkata" ,
                                day: "2-digit" , month: "short" , year: "numeric" , hour: "2-digit" , minute: "2-digit"
                                , second: "2-digit" , hour12: true }) .replace("am", "AM" ) .replace("pm", "PM" ) %>
                        </div>

                    </div>

                    <!-- RIGHT ACTION -->
                    <div>

                        <% if (session.sessionId !== currentSessionId) { %>
                            <form method="POST" action="/sessions/logout">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>"> <!-- ✅ ADD THIS -->
                                <input type="hidden" name="sessionId" value="<%= session.sessionId %>">
                                <button class="btn btn-outline-danger btn-sm">
                                    Logout
                                </button>
                            </form>
                            <% } else { %>
                                <span class="badge bg-success px-3 py-2">
                                    This Device
                                </span>
                                <% } %>

                    </div>

                </div>

                <% }) %>


                    <% } else { %>
                        <h3 class="text-center">There is/are no active session/s</h3>
                        <% } %>
    </div>


</div>