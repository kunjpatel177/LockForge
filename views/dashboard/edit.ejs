<div class="dashboard-header">
    <h2 class="mb-4 fw-semibold">Edit Credential</h2>
    
    <!-- BACK -->
    <a href="/dashboard" class="btn btn-dark btn-sm mb-3">
        ← Back
    </a>
</div>


<!-- ================= EDIT FORM ================= -->

<div class="credential-card edit-card">

    <form id="editForm" method="POST" action="/edit/<%= cred._id %>">

        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <!-- SERVICE -->
        <div class="mb-4">
            <label class="form-label fw-medium" for="service">Service</label>
            <input 
                id="service"
                type="text" 
                name="service" 
                class="form-control" 
                value="<%= cred.service %>"
                required
            >
        </div>

        <!-- FIELDS -->
        <div id="fieldsContainer" class="fields-wrapper"></div>

        <!-- ADD FIELD -->
        <button type="button" id="addFieldBtn" class="btn btn-outline-primary btn-sm px-4 py-2 mt-3">
            <i class="fa fa-plus"></i> Add Field
        </button>

        <!-- SUBMIT -->
        <div class="mt-4">
            <button class="btn btn-success px-4 py-2">
                Update Credential
            </button>
        </div>

    </form>

</div>


<!-- ================= PASS DATA ================= -->

<script id="edit-data" type="application/json">
    <%- JSON.stringify(cred.fields || []) %>
</script>

<!-- <script src="/js/script.js"></script> -->

<script>
document.addEventListener("DOMContentLoaded", () => {

    const dataElement = document.getElementById("edit-data");
    if (!dataElement) return;

    let fields = [];

    try {
        fields = JSON.parse(dataElement.textContent);
    } catch (err) {
        console.error("Error parsing edit data:", err);
    }

    if (fields.length > 0) {
        fields.forEach(field => {
            addField(field.label || "", field.value || "", field.type || "text");
        });
    } else {
        addField("email", "", "text");
        addField("password", "", "password");
    }
});
</script>