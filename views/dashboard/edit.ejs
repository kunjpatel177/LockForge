<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Edit Credential</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/edit.css">
</head>

<body>

    <div class="container py-5">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">✏️ Edit Credential</h2>
            <div>
                <a href="/dashboard" class="btn btn-secondary btn-sm">⬅ Dashboard</a>
                <!-- <a href="/logout" class="btn btn-danger btn-sm ms-2">Logout</a> -->
                <form action="/logout" method="POST" style="display:inline;">
                    <button class="btn btn-danger btn-sm">Logout</button>
                </form>
            </div>
        </div>

        <!-- CARD -->
        <div class="card shadow-lg p-4 edit-card">

            <form method="POST" action="/edit/<%= cred._id %>">

                <!-- Service Name -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Service</label>
                    <input type="text" name="service" value="<%= cred.service %>" class="form-control"
                        placeholder="e.g. Gmail" required>
                </div>

                <!-- Dynamic Fields -->
                <div id="fieldsContainer" class="mb-3"></div>

                <!-- Add Field -->
                <button type="button" id="addFieldBtn" class="btn btn-outline-primary mb-3">
                    + Add Field
                </button>

                <!-- Submit -->
                <button type="submit" class="btn btn-success w-100">
                    Update Credential
                </button>

            </form>

        </div>

    </div>

    <!-- ================= DATA + SCRIPT ================= -->
    <%- include("../partials/fieldTemplate") %>
        <script id="edit-data" type="application/json">
    <%- JSON.stringify(cred.fields || []) %>
</script>

        <script src="/js/script.js"></script>

</body>

</html>