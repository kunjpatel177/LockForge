<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Login | Password Manager</title>

    <!-- Bootstrap (MATCHED VERSION) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/auth.css">
</head>

<body>

    <div class="container d-flex flex-column align-items-center justify-content-center min-vh-100">

        <!-- ✅ FLASH MESSAGE (CORRECT POSITION) -->
        <div class="w-100 d-flex justify-content-center">
            <div class="col-md-6">
                <%#- include("../partials/flash") %>
                <%- include("../partials/toast") %>
            </div>
        </div>

        <!-- LOGIN CARD -->
        <div class="card login-card p-4 shadow-lg mt-3">

            <h3 class="text-center">🔐 Password Manager</h3>
            <hr>
            <p class="text-center text-muted mb-4">Login to your vault</p>

            <form method="POST" action="/login" class="needs-validation" novalidate>

                <!-- EMAIL -->
                <div class="mb-3">
                    <label class="form-label" for="email">Email</label>
                    <!-- <input 
                    type="email" 
                    name="email" 
                    id="email" 
                    class="form-control" 
                    placeholder="Enter your email" 
                    required
                >
                <div class="invalid-feedback">
                    Please enter a valid email.
                </div> -->
                    <input type="email" name="email" id="email" class="form-control" value="<%= old.email || '' %>"
                        placeholder="Enter your email" required>
                    <div class="invalid-feedback">
                        Please enter an email.
                    </div>

                    <% if (errors.email) { %>
                        <div class="text-danger">
                            <%= errors.email %>
                        </div>
                        <% } %>
                </div>

                <!-- PASSWORD -->
                <div class="mb-3">
                    <label class="form-label" for="master-password">Master Password</label>
                    <!-- <input 
                    type="password" 
                    name="password" 
                    id="master-password" 
                    class="form-control" 
                    placeholder="Enter password"
                    required
                >
                <div class="invalid-feedback">
                    Please enter your master password.
                </div> -->
                    <input type="password" name="password" id="master-password" class="form-control"
                        placeholder="Enter password" required>
                    <div class="invalid-feedback">
                        Please enter a Password.
                    </div>

                    <% if (errors.password) { %>
                        <div class="text-danger">
                            <%= errors.password %>
                        </div>
                        <% } %>
                </div>

                <!-- SUBMIT -->
                <button type="submit" class="btn btn-primary w-100 login-btn">
                    Login
                </button>

            </form>

            <hr>

            <p class="text-center">
                Don't have an account?
                <a href="/register">Register</a>
            </p>

        </div>

    </div>

    <!-- ✅ MATCHING BOOTSTRAP JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <script src="/js/toast.js"></script>

    <!-- VALIDATION -->
    <script src="/js/validation.js"></script>

</body>

</html>