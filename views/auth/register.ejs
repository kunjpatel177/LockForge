<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Register | Password Manager</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/auth.css">
</head>

<body>

    <%- include("../partials/flash") %>

        <div class="w-100 d-flex justify-content-center">
            <div class="col-md-6">
                <%#- include("../partials/flash") %>
                <%- include("../partials/toast") %>
            </div>
        </div>
        <div class="container d-flex align-items-center justify-content-center min-vh-100">


            <div class="card auth-card p-5 shadow-lg">

                <h2 class="text-center mb-3">📝 Create Account</h2>
                <p class="text-center text-muted mb-4">Secure your credentials</p>

                <form method="POST" action="/register" class="needs-validation" novalidate>

                    <!-- Full Name -->
                    <div class="mb-2">
                        <label class="form-label" for="fullName">Full Name</label>
                        <input type="text" name="fullName" id="fullName" placeholder="Enter your full name"
                            class="form-control" value="<%= old.fullName || '' %>" required>

                        <div class="invalid-feedback">
                            Please enter your Full Name.
                        </div>
                        <% if (errors.fullName) { %>
                            <div class="text-danger">
                                <%= errors.fullName %>
                            </div>
                            <% } %>
                    </div>

                    <!-- Email -->
                    <div class="mb-2">
                        <label class="form-label" for="email">Email</label>
                        <input type="email" name="email" id="email" placeholder="Enter your email" class="form-control"
                            value="<%= old.email || '' %>" required>

                        <div class="invalid-feedback">
                            Please enter an email.
                        </div>
                        <% if (errors.email) { %>
                            <div class="text-danger">
                                <%= errors.email %>
                            </div>
                            <% } %>
                    </div>

                    <!-- Username -->
                    <div class="mb-2">
                        <label class="form-label" for="username">Username</label>
                        <input type="text" name="username" placeholder="Enter your username" id="username"
                            class="form-control" value="<%= old.username || '' %>" required>

                        <div class="invalid-feedback">
                            Please enter a Username.
                        </div>
                        <% if (errors.username) { %>
                            <div class="text-danger">
                                <%= errors.username %>
                            </div>
                            <% } %>
                    </div>

                    <!-- Password -->
                    <div class="mb-3">
                        <!-- <input type="password" name="password" class="form-control"> -->
                        <label class="form-label" for="password">Master Password</label>
                        <input type="password" name="password" placeholder="Set your Master Password" id="password"
                            class="form-control" required>

                        <div class="invalid-feedback">
                            Please enter a Password.
                        </div>
                        <% if (errors.password) { %>
                            <div class="text-danger">
                                <%= errors.password %>
                            </div>
                            <% } %>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="btn btn-success w-100 auth-btn">
                        Register
                    </button>

                </form>

                <hr>

                <p class="text-center">
                    Already have an account?
                    <a href="/">Login</a>
                </p>

            </div>

        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

        <script src="/js/toast.js"></script>
        <!-- VALIDATION -->
        <script src="/js/validation.js"></script>

</body>

</html>